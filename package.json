{
  "name": "mr-cursored",
  "version": "0.1.0",
  "description": "AI-Optimized Project Scaffolder - A protocol + CLI that turns high-level intents into repeatable, AI-friendly project skeletons with strong guardrails",
  "main": "dist/index.js",
  "bin": {
    "mr-cursored": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "fmt": "prettier --write src",
    "doctor": "npm run lint && npm run test && npm run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node -e \"import('./dist/scripts/migrate.js')\"",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx src/scripts/seed.ts"
  },
  "keywords": [
    "ai",
    "scaffolding",
    "cli",
    "typescript",
    "drizzle",
    "nextjs",
    "cursor",
    "copilot",
    "development",
    "automation"
  ],
  "author": "bohselecta",
  "license": "MIT",
  "dependencies": {
    "execa": "^8.0.1",
    "zod": "^3.22.4",
    "drizzle-orm": "^0.44.7",
    "better-sqlite3": "^9.2.2",
    "@libsql/client": "^0.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/better-sqlite3": "^7.6.8",
    "typescript": "^5.3.0",
    "tsx": "^4.6.0",
    "vitest": "^1.0.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "prettier": "^3.1.0",
    "drizzle-kit": "^0.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bohselecta/mr-cursored.git"
  },
  "bugs": {
    "url": "https://github.com/bohselecta/mr-cursored/issues"
  },
  "homepage": "https://github.com/bohselecta/mr-cursored#readme"
}